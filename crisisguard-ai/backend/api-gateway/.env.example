# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Firebase
FIREBASE_PROJECT_ID=crisisguard-ai
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=crisisguard-ai.firebaseapp.com
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Redis
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=debug

# Services (internal URLs)
ALERT_SERVICE_URL=http://localhost:8000
AI_GATEWAY_URL=http://localhost:8001
NOTIFICATION_SERVICE_URL=http://localhost:3002
WEBSOCKET_SERVICE_URL=http://localhost:3003
