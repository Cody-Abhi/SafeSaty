{
  "rules": {
    ".info": {
      ".read": true
    },

    "presence": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "alerts": {
      "$propertyId": {
        ".read":  "auth != null",
        ".write": false
      }
    },

    "location": {
      "$propertyId": {
        ".read":  "auth != null",
        ".write": false
      }
    },

    "occupancy": {
      "$propertyId": {
        ".read":  "auth != null",
        ".write": false
      }
    },

    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
